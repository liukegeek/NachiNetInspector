L99%=0
L99%=I449+I450

'-----------GRIP OPEN--------'
IF (DI_DryRun=1 AND L99%>0) OR DO_Manual=0

WINDOW 80,310,100,100	'用户画面开启
TITLE "抓手打开"	'用户画面标题设定     
PAUSE 300
GACTIVE(1)		'显示
L1$="确认抓手无件"
L2$ ="确认将抓手打开吗?"
GMSGBOX 2,2,L1$,L2$,2,"","","",""	'确认［是/否］
L10$ = GETKEY$(4) 	'等待按下.按钮
L10% = ORD(L10$) 	'将按钮代码转换为数值
IF (&H01 = L10%) 	'选择了［是］：复位处理
GACTIVE(0)'不显示
ELSE
USRERR 7036
ENDIF
ENDIF
